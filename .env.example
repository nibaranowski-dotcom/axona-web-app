# Axona — local dev env. Copy to .env, then: docker compose up -d (FND.3).
# These are dev-only defaults — never commit real secrets.

# --- Postgres (pgvector) ---
POSTGRES_USER=axona
POSTGRES_PASSWORD=axona
POSTGRES_DB=axona
POSTGRES_PORT=5432
DATABASE_URL=postgresql://axona:axona@localhost:5432/axona

# --- Redis (BullMQ) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO (S3-compatible blob store) ---
MINIO_ROOT_USER=axona
MINIO_ROOT_PASSWORD=axona-secret
MINIO_CONSOLE_PORT=9001
S3_PORT=9000
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=axona-files
S3_ACCESS_KEY=axona
S3_SECRET_KEY=axona-secret

# --- App / AI ---
ANTHROPIC_API_KEY=
# Agent runtime model (ART.1) — configurable; confirm the current name at docs.claude.com
ANTHROPIC_MODEL=claude-sonnet-4-6
AUTH_SECRET=
