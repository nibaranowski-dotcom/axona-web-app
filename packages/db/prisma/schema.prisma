// Axona data model.
// Scaffolded in FND.1; built per build-spec §3:
//   FND.5  Core / tenancy (Org, User, Role, Module, ModuleGroup)   <-- this file
//   FND.6  Agents / Chats / Workflows / Runs
//   FND.7  Projects / Files / MatrixColumn (+ pgvector embedding)
//   FND.8  Machines + MachineSignal (time-series)
//   FND.9  Value-chain entities
//   FND.10 Robotics + back-office entities
// Org-scoped client + query helpers + first migration: FND.11.
//
// Multi-tenancy invariant (CLAUDE.md): every tenant-owned model carries `orgId`
// with a relation + @@index([orgId]). This is the basis for org-scoped queries
// (FND.11) and per-tenant isolation (ISO.1).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ─── Core / tenancy (§3.1) ─────────────────────────────────────────────────

/// The tenant root. Everything tenant-owned hangs off an Org via `orgId`.
model Org {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])
  name      String
  email     String   @unique
  role      Role
  createdAt DateTime @default(now())

  @@index([orgId])
}

enum Role {
  ADMIN
  OPS
  ENGINEER
  SALES
  FINANCE
  TECH
  VIEWER
}

/// Global system catalog of product modules (not tenant-owned — no orgId).
/// Enablement per tenant lands later (org settings / SET.1).
model Module {
  id         String      @id
  key        String      @unique
  name       String
  group      ModuleGroup
  orderIndex Int
}

enum ModuleGroup {
  CORE
  VALUE_CHAIN
  ROBOTICS
  BACK_OFFICE
}

// ─── Agents / chats / workflows / runs (§3.2) ──────────────────────────────
// Tenancy: Agent/Chat/Workflow are tenant-owned -> orgId + @@index([orgId]).
// AgentRun/Message/WorkflowRun inherit tenancy through their parent FK (indexed).

model Agent {
  id          String     @id @default(cuid())
  orgId       String
  moduleKey   String // owning module, or "core"
  name        String // "Sourcing agent"
  code        String // "proc-04"
  role        String // "SOURCING"
  description String // one-liner: what it does
  state       AgentState @default(LIVE)
  runs        AgentRun[]

  @@index([orgId])
}

enum AgentState {
  LIVE
  WORKING
  CRITICAL
  OFFLINE
}

model Chat {
  id        String    @id @default(cuid())
  orgId     String
  agentId   String?
  userId    String
  scope     String
  createdAt DateTime  @default(now())
  messages  Message[]

  @@index([orgId])
  @@index([agentId])
  @@index([userId])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id])
  role      MsgRole
  text      String
  citations Json?
  createdAt DateTime @default(now())

  @@index([chatId])
}

enum MsgRole {
  USER
  AGENT
  SYSTEM
}

model Workflow {
  id          String         @id @default(cuid())
  orgId       String
  moduleKey   String
  name        String
  description String
  status      WorkflowStatus @default(DRAFT)
  trigger     Json // event spec
  steps       Json // ordered nodes: agent steps, decision gates, output
  runs        WorkflowRun[]

  @@index([orgId])
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
}

model WorkflowRun {
  id         String    @id @default(cuid())
  workflowId String
  workflow   Workflow  @relation(fields: [workflowId], references: [id])
  status     RunStatus
  /// Freeform run trace (scan/correlate/draft/policy-check/result). The
  /// immutable event log + calibrated `confidence` + `approver` columns land in
  /// ONT.1 / CONF.1 / AUDIT.3 — do not add those columns here yet.
  trace      Json
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  @@index([workflowId])
}

enum RunStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

model AgentRun {
  id        String    @id @default(cuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id])
  input     Json
  /// Freeform run trace (scan/correlate/draft/policy-check/result). The
  /// immutable event log + calibrated `confidence` + `approver` columns land in
  /// ONT.1 / CONF.1 / AUDIT.3 — do not add those columns here yet.
  trace     Json
  status    RunStatus
  createdAt DateTime  @default(now())

  @@index([agentId])
}

// ─── Projects & files — Hebbia-style matrix (§3.3) ─────────────────────────
// Tenancy: Project is tenant-owned -> orgId + @@index([orgId]).
// File/MatrixColumn inherit tenancy through an indexed projectId FK.

model Project {
  id          String        @id @default(cuid())
  orgId       String
  moduleKey   String
  name        String
  description String
  status      ProjectStatus
  members     Json
  files       File[]
  updatedAt   DateTime      @updatedAt

  @@index([orgId])
}

enum ProjectStatus {
  ACTIVE
  IN_REVIEW
  BLOCKED
  DONE
}

model File {
  id        String                 @id @default(cuid())
  projectId String
  project   Project                @relation(fields: [projectId], references: [id])
  name      String
  ext       String
  sizeBytes Int
  blobKey   String
  type      String // Change, Spec, Quote, Report, Data, Memo, Plan…
  linkedTo  String? // e.g. "Engineering · SERVO-205"
  /// AI-extracted column values keyed by columnId (the file-matrix substrate,
  /// MTX.1). This + `embedding` feed operational memory (MEM.1) later — extend
  /// there; do NOT add memory/graph columns here.
  extracted Json
  /// pgvector column. Prisma can't introspect Unsupported types, so the actual
  /// `vector` column + ANN index are created via raw SQL in the FND.11 migration.
  embedding Unsupported("vector")?

  modifiedAt DateTime @updatedAt

  @@index([projectId])
}

// Answers live in File.extracted[columnId].
// projectId is a scalar FK + index (no formal relation — §3.3 has no
// Project.matrixColumns array; matches the scalar-orgId pattern). The one-pass
// relation/FK wiring happens at FND.11 (see "FND.11 deferred decisions").
model MatrixColumn {
  id        String   @id @default(cuid())
  projectId String
  question  String
  createdBy String
  createdAt DateTime @default(now())

  @@index([projectId])
}

// ─── Machines — own plant + mobile units (§3.4) ────────────────────────────
// Tenancy: Machine is tenant-owned -> orgId + @@index([orgId]).
// MachineSignal inherits tenancy through an indexed machineId FK.

model Machine {
  id              String          @id @default(cuid())
  orgId           String
  assetId         String // "CNC-02"
  name            String
  kind            MachineKind // FIXED | MOBILE
  category        String // CNC, SMT, test-rig, AMR, forklift, demo-unit…
  location        String
  status          MachineStatus
  utilization     Int // 0-100
  health          String // "Healthy", "Re-cal overdue"…
  healthLevel     HealthLevel
  telemetryOnline Boolean
  signals         MachineSignal[]

  @@index([orgId])
}

enum MachineKind {
  FIXED
  MOBILE
}

enum MachineStatus {
  RUNNING
  IDLE
  MAINTENANCE
  CHARGING
  FAULT
}

enum HealthLevel {
  OK
  WATCH
  BAD
}

/// Plant-telemetry time-series. First-class typed telemetry input (TEL.1) that
/// feeds operational memory (MEM.1). The prototype models it as a regular table;
/// the Timescale/hypertable + immutable event-log wiring is TEL.1 — not here yet.
/// The composite @@index([machineId, ts]) keeps time-windowed reads efficient.
model MachineSignal {
  id        String   @id @default(cuid())
  machineId String
  machine   Machine  @relation(fields: [machineId], references: [id])
  ts        DateTime
  metric    String
  value     Float

  @@index([machineId, ts])
}

// ─── Value-chain entities (§3.5) ───────────────────────────────────────────
// All tenant-owned -> scalar orgId + @@index([orgId]). Cross-entity FKs stay
// scalar + indexed (formal @relation + FK constraints come in the FND.11 pass).

model Supplier {
  id        String @id @default(cuid())
  orgId     String
  name      String
  tier      Int
  riskScore Float
  onTimePct Float

  @@index([orgId])
}

model Part {
  id           String @id @default(cuid())
  orgId        String
  sku          String
  name         String
  onHand       Int
  reorderPoint Int
  leadDays     Int

  @@index([orgId])
}

model PurchaseOrder {
  id               String    @id @default(cuid())
  orgId            String
  code             String
  supplierId       String
  partId           String
  qty              Int
  value            Float
  /// Agent-drafted PO surface — the propose→approve→audit moat. The approval
  /// state machine (DRAFTED→AWAITING_APPROVAL→APPROVED→SENT) lives in RBAC.4;
  /// the immutable who/model/confidence/approver record lands in AUDIT.3.
  status           POStatus
  draftedByAgentId String?
  eta              DateTime?

  @@index([orgId])
  @@index([supplierId])
  @@index([partId])
  @@index([draftedByAgentId])
}

enum POStatus {
  DRAFTED
  AWAITING_APPROVAL
  APPROVED
  SENT
  RECEIVED
}

model WorkOrderMfg {
  id        String    @id @default(cuid())
  orgId     String
  /// As-built genealogy anchor — parts·serials·firmware captured AS BUILT, never
  /// reconstructed (capture fidelity caps the moat). The genealogy graph over
  /// this serial lands in ONT.2; keep capture clean here.
  serial    String
  product   String
  station   String
  status    String
  startedAt DateTime?

  @@index([orgId])
}

model NCR {
  id       String   @id @default(cuid())
  orgId    String
  code     String
  defect   String
  linkedTo String
  severity Severity
  status   String

  @@index([orgId])
}

enum Severity {
  MINOR
  MAJOR
  CRITICAL
}

/// SPC quality telemetry (measurement vs UCL/LCL/mean). First-class quality
/// signal feeding operational memory (MEM.1); modeled as a plain table for now.
model SpcSample {
  id             String   @id @default(cuid())
  orgId          String
  characteristic String
  serial         String
  value          Float
  ucl            Float
  lcl            Float
  mean           Float
  ts             DateTime

  @@index([orgId])
  @@index([characteristic, ts])
}

model Cert {
  id      String   @id @default(cuid())
  orgId   String
  name    String
  scope   String
  validTo DateTime
  status  String

  @@index([orgId])
}

model Deal {
  id          String      @id @default(cuid())
  orgId       String
  account     String
  config      String
  value       Float
  stage       DealStage
  closeDate   DateTime?
  feasibility Feasibility

  @@index([orgId])
}

enum DealStage {
  QUALIFY
  DEMO
  PROPOSAL
  NEGOTIATION
  COMMIT
}

enum Feasibility {
  ON_TIME
  AT_RISK
  NOT_CHECKED
}

model Campaign {
  id       String @id @default(cuid())
  orgId    String
  name     String
  channel  String
  mqls     Int
  pipeline Float
  roi      Float
  status   String

  @@index([orgId])
}

model Delivery {
  id            String        @id @default(cuid())
  orgId         String
  code          String
  account       String
  destination   String
  units         String
  stage         DeliveryStage
  committedDate DateTime
  etaDate       DateTime
  riskState     String

  @@index([orgId])
  @@index([stage])
}

enum DeliveryStage {
  ALLOC
  CRATE
  FREIGHT
  CUSTOMS
  ONSITE
  COMMISSION
  ACTIVE
}

// ─── Robotics + back office (§3.6) ─────────────────────────────────────────
// All tenant-owned -> scalar orgId + @@index([orgId]). Cross-entity FKs stay
// scalar + indexed (formal @relation + FK constraints come in the FND.11 pass).
// REUSES the Severity enum defined in §3.5 (WorkOrderField/SafetyIncident/CVE).

model Robot {
  id        String @id @default(cuid())
  orgId     String
  /// Links a deployed unit back to its as-built genealogy (parts·serials·
  /// firmware) — the ONT.2 genealogy graph keys on this serial.
  serial    String
  model     String
  customer  String
  site      String
  uptimePct Float
  firmware  String
  status    String
  lat       Float?
  lng       Float?

  @@index([orgId])
}

/// First-class fleet telemetry time-series (TEL.1) feeding operational memory
/// (MEM.1). Plain table for the prototype; Timescale/hypertable + event-log
/// wiring is TEL.1. Composite @@index([robotId, ts]) for time-windowed reads.
model TelemetryPoint {
  id      String   @id @default(cuid())
  orgId   String
  robotId String
  ts      DateTime
  metric  String
  value   Float

  @@index([orgId])
  @@index([robotId, ts])
}

model WorkOrderField {
  id          String    @id @default(cuid())
  orgId       String
  code        String
  robotSerial String
  site        String
  issue       String
  slaDueAt    DateTime?
  techId      String?
  status      String
  severity    Severity

  @@index([orgId])
  @@index([techId])
  @@index([slaDueAt])
}

model Technician {
  id       String @id @default(cuid())
  orgId    String
  name     String
  initials String
  site     String
  status   String
  certs    Json // cert matrix: {certKey: {state, expiresAt}}

  @@index([orgId])
}

model ECO {
  id         String @id @default(cuid())
  orgId      String
  code       String
  title      String
  changeType String
  affected   String
  /// Gated change-control state (DRAFT/REVIEW/APPROVED/RELEASED). The release
  /// approval state machine is RBAC.4; the model·confidence·approver record is
  /// AUDIT.3 — keep this as a plain status here.
  stage      String

  @@index([orgId])
}

model FirmwareRelease {
  id      String @id @default(cuid())
  orgId   String
  version String
  note    String
  state   String

  @@index([orgId])
}

model CompatCell {
  id        String @id @default(cuid())
  orgId     String
  hwRev     String
  fwVersion String
  state     String // cert/compatible/in-test/na

  @@index([orgId])
  @@index([hwRev, fwVersion])
}

/// Autonomy telemetry (autonomy-rate / takeovers per site) feeding operational
/// memory (MEM.1). Plain table for the prototype.
model AutonomyMetric {
  id             String   @id @default(cuid())
  orgId          String
  site           String
  ts             DateTime
  autonomyRate   Float
  takeoversPer1k Float
  policyVersion  String

  @@index([orgId])
  @@index([site, ts])
}

model SafetyIncident {
  id          String   @id @default(cuid())
  orgId       String
  code        String
  type        String
  robotSerial String
  site        String
  severity    Severity
  status      String

  @@index([orgId])
}

model PolicyVersion {
  id      String @id @default(cuid())
  orgId   String
  version String
  note    String
  /// Gated rollback/promotion state (current/canary/standby). Policy rollback is
  /// a gated action: approval state machine = RBAC.4; model·confidence·approver
  /// record = AUDIT.3 — keep this as a plain state here.
  state   String

  @@index([orgId])
}

model LedgerEntry {
  id      String @id @default(cuid())
  orgId   String
  period  String
  account String
  amount  Float
  kind    String

  @@index([orgId])
}

model Invoice {
  id      String    @id @default(cuid())
  orgId   String
  code    String
  account String
  source  String
  amount  Float
  terms   String
  dueDate DateTime?
  status  String

  @@index([orgId])
}

model UnitEconomic {
  id        String @id @default(cuid())
  orgId     String
  product   String
  asp       Float
  cogs      Float
  marginPct Float
  trend     String

  @@index([orgId])
}

model Requisition {
  id     String @id @default(cuid())
  orgId  String
  role   String
  filled Int
  target Int

  @@index([orgId])
}

model CVE {
  id            String   @id @default(cuid())
  orgId         String
  code          String
  severity      Severity
  affectedUnits Int
  status        String

  @@index([orgId])
}

model Obligation {
  id         String @id @default(cuid())
  orgId      String
  account    String
  obligation String
  actual     String
  state      String // SLA tracked vs live ops

  @@index([orgId])
}

model ExportLicense {
  id          String @id @default(cuid())
  orgId       String
  destination String
  code        String
  state       String

  @@index([orgId])
}

model LegalMatter {
  id       String @id @default(cuid())
  orgId    String
  type     String
  title    String
  linkedTo String
  status   String

  @@index([orgId])
}
