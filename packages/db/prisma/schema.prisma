// Axona data model.
// Scaffolded in FND.1; built per build-spec §3:
//   FND.5  Core / tenancy (Org, User, Role, Module, ModuleGroup)   <-- this file
//   FND.6  Agents / Chats / Workflows / Runs
//   FND.7  Projects / Files / MatrixColumn (+ pgvector embedding)
//   FND.8  Machines + MachineSignal (time-series)
//   FND.9  Value-chain entities
//   FND.10 Robotics + back-office entities
// Org-scoped client + query helpers + first migration: FND.11.
//
// Multi-tenancy invariant (CLAUDE.md): every tenant-owned model carries `orgId`
// with a relation + @@index([orgId]). This is the basis for org-scoped queries
// (FND.11) and per-tenant isolation (ISO.1).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ─── Core / tenancy (§3.1) ─────────────────────────────────────────────────

/// The tenant root. Everything tenant-owned hangs off an Org via `orgId`.
model Org {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])
  name      String
  email     String   @unique
  role      Role
  createdAt DateTime @default(now())

  @@index([orgId])
}

enum Role {
  ADMIN
  OPS
  ENGINEER
  SALES
  FINANCE
  TECH
  VIEWER
}

/// Global system catalog of product modules (not tenant-owned — no orgId).
/// Enablement per tenant lands later (org settings / SET.1).
model Module {
  id         String      @id
  key        String      @unique
  name       String
  group      ModuleGroup
  orderIndex Int
}

enum ModuleGroup {
  CORE
  VALUE_CHAIN
  ROBOTICS
  BACK_OFFICE
}

// ─── Agents / chats / workflows / runs (§3.2) ──────────────────────────────
// Tenancy: Agent/Chat/Workflow are tenant-owned -> orgId + @@index([orgId]).
// AgentRun/Message/WorkflowRun inherit tenancy through their parent FK (indexed).

model Agent {
  id          String     @id @default(cuid())
  orgId       String
  moduleKey   String // owning module, or "core"
  name        String // "Sourcing agent"
  code        String // "proc-04"
  role        String // "SOURCING"
  description String // one-liner: what it does
  state       AgentState @default(LIVE)
  runs        AgentRun[]

  @@index([orgId])
}

enum AgentState {
  LIVE
  WORKING
  CRITICAL
  OFFLINE
}

model Chat {
  id        String    @id @default(cuid())
  orgId     String
  agentId   String?
  userId    String
  scope     String
  createdAt DateTime  @default(now())
  messages  Message[]

  @@index([orgId])
  @@index([agentId])
  @@index([userId])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id])
  role      MsgRole
  text      String
  citations Json?
  createdAt DateTime @default(now())

  @@index([chatId])
}

enum MsgRole {
  USER
  AGENT
  SYSTEM
}

model Workflow {
  id          String         @id @default(cuid())
  orgId       String
  moduleKey   String
  name        String
  description String
  status      WorkflowStatus @default(DRAFT)
  trigger     Json // event spec
  steps       Json // ordered nodes: agent steps, decision gates, output
  runs        WorkflowRun[]

  @@index([orgId])
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
}

model WorkflowRun {
  id         String    @id @default(cuid())
  workflowId String
  workflow   Workflow  @relation(fields: [workflowId], references: [id])
  status     RunStatus
  /// Freeform run trace (scan/correlate/draft/policy-check/result). The
  /// immutable event log + calibrated `confidence` + `approver` columns land in
  /// ONT.1 / CONF.1 / AUDIT.3 — do not add those columns here yet.
  trace      Json
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  @@index([workflowId])
}

enum RunStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

model AgentRun {
  id        String    @id @default(cuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id])
  input     Json
  /// Freeform run trace (scan/correlate/draft/policy-check/result). The
  /// immutable event log + calibrated `confidence` + `approver` columns land in
  /// ONT.1 / CONF.1 / AUDIT.3 — do not add those columns here yet.
  trace     Json
  status    RunStatus
  createdAt DateTime  @default(now())

  @@index([agentId])
}

// ─── Projects & files — Hebbia-style matrix (§3.3) ─────────────────────────
// Tenancy: Project is tenant-owned -> orgId + @@index([orgId]).
// File/MatrixColumn inherit tenancy through an indexed projectId FK.

model Project {
  id          String        @id @default(cuid())
  orgId       String
  moduleKey   String
  name        String
  description String
  status      ProjectStatus
  members     Json
  files       File[]
  updatedAt   DateTime      @updatedAt

  @@index([orgId])
}

enum ProjectStatus {
  ACTIVE
  IN_REVIEW
  BLOCKED
  DONE
}

model File {
  id        String                 @id @default(cuid())
  projectId String
  project   Project                @relation(fields: [projectId], references: [id])
  name      String
  ext       String
  sizeBytes Int
  blobKey   String
  type      String // Change, Spec, Quote, Report, Data, Memo, Plan…
  linkedTo  String? // e.g. "Engineering · SERVO-205"
  /// AI-extracted column values keyed by columnId (the file-matrix substrate,
  /// MTX.1). This + `embedding` feed operational memory (MEM.1) later — extend
  /// there; do NOT add memory/graph columns here.
  extracted Json
  /// pgvector column. Prisma can't introspect Unsupported types, so the actual
  /// `vector` column + ANN index are created via raw SQL in the FND.11 migration.
  embedding Unsupported("vector")?

  modifiedAt DateTime @updatedAt

  @@index([projectId])
}

// Answers live in File.extracted[columnId].
// projectId is a scalar FK + index (no formal relation — §3.3 has no
// Project.matrixColumns array; matches the scalar-orgId pattern). The one-pass
// relation/FK wiring happens at FND.11 (see "FND.11 deferred decisions").
model MatrixColumn {
  id        String   @id @default(cuid())
  projectId String
  question  String
  createdBy String
  createdAt DateTime @default(now())

  @@index([projectId])
}
